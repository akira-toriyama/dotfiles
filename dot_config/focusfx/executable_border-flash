#!/bin/sh
# focusfx 枠フラッシュ。フォーカス変更時にテーマを1つ抽選して glow 点滅し、
# 直後に bordersrc 相当の steady-state へ自己復帰する。
# 太さ・時間は固定。テーマ追加 = パレット変数を足し THEMES に名前を足すだけ。
# PATH(Homebrew) は LaunchAgent の EnvironmentVariables で解決済み。

WIDTH=40        # 枠の太さ（固定）
FLASHES=7       # 点滅回数（固定）
INTERVAL=0.03   # 点滅間隔・秒（固定）／計 ≈ 0.21s

# ===== テーマ定義（色 0xAARRGGBB / 半角スペース区切り）==================

# HADE系 — 原色ハデハデ
HADE="0xffff0000 0xff00ff00 0xff0000ff 0xffffff00 0xffff00ff 0xff00ffff"

# NEON系 — 電飾ネオン
NEON="0xff00e5ff 0xffff00ff 0xff39ff14 0xfffe019a 0xff04d9ff 0xffbc13fe"

# KAWAII系 — パステル可愛い
KAWAII="0xffffb3d9 0xffd9b3ff 0xffb3ffd9 0xffffe0b3 0xffb3e0ff 0xffffc6e0"

# 抽選対象（ここに名前を並べた分だけ等確率で選ばれる）
THEMES="HADE NEON KAWAII"

# ======================================================================

# テーマ抽選
set -- $THEMES
ti=$(( RANDOM % $# + 1 ))
theme=$(eval echo "\${$ti}")
eval "palette=\$$theme"

# パレット展開し、連続同色を排除しながら点滅
set -- $palette
pn=$#
prev=0
k=0
while [ "$k" -lt "$FLASHES" ]; do
  ci=$(( RANDOM % pn + 1 ))
  [ "$ci" -eq "$prev" ] && ci=$(( ci % pn + 1 ))
  prev=$ci
  color=$(eval echo "\${$ci}")
  borders width="$WIDTH" hidpi=on active_color="glow($color)" >/dev/null 2>&1
  sleep "$INTERVAL"
  k=$(( k + 1 ))
done

# steady-state 復帰（bordersrc 相当）
borders style=round width=6.0 hidpi=on \
  active_color="gradient(top_left=0xff7aa2f7,bottom_right=0xffbb9af7)" \
  inactive_color=0x00000000 >/dev/null 2>&1
