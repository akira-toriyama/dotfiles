{
  "title": "ist mouse (Elecom vendor_id 1390)",
  "rules": [
    {
      "description": "ist mouse: 親指上(button7) をレイヤーキー化 (長押し中レイヤー / 単押し Esc)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "pointing_button": "button7",
            "modifiers": { "optional": ["any"] }
          },
          "to": [{ "set_variable": { "name": "button7_down", "value": 1 } }],
          "to_if_alone": [{ "key_code": "escape" }],
          "to_after_key_up": [
            { "set_variable": { "name": "button7_down", "value": 0 } }
          ],
          "conditions": [
            { "type": "variable_if", "name": "button7_down", "value": 0 },
            { "type": "device_if", "identifiers": [{ "vendor_id": 1390 }] }
          ]
        }
      ]
    },
    {
      "description": "ist mouse: レイヤー中 button2 -> AltTab all spaces (⌃⌘Tab)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "pointing_button": "button2",
            "modifiers": { "optional": ["any"] }
          },
          "to": [{ "key_code": "tab", "modifiers": ["command", "control"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1390 }] },
            { "type": "variable_if", "name": "button7_down", "value": 1 }
          ]
        }
      ]
    },
    {
      "description": "ist mouse: レイヤー中 button1 -> AltTab current (⌥Tab) / 通常 button2 -> ⌥修飾(単押し右クリック)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "pointing_button": "button1",
            "modifiers": { "optional": ["any"] }
          },
          "to": [{ "key_code": "tab", "modifiers": ["option"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1390 }] },
            { "type": "variable_if", "name": "button7_down", "value": 1 }
          ]
        },
        {
          "type": "basic",
          "from": {
            "pointing_button": "button2",
            "modifiers": { "optional": ["any"] }
          },
          "to": [{ "key_code": "left_option" }],
          "to_if_alone": [{ "pointing_button": "button2" }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1390 }] }
          ]
        }
      ]
    },
    {
      "description": "ist mouse: レイヤー中 button3 -> Mission Control (⌥⇧Space) / 通常 button3 -> ⌃修飾(単押し維持)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "pointing_button": "button3",
            "modifiers": { "optional": ["any"] }
          },
          "to": [{ "key_code": "spacebar", "modifiers": ["option", "shift"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1390 }] },
            { "type": "variable_if", "name": "button7_down", "value": 1 }
          ]
        },
        {
          "type": "basic",
          "from": {
            "pointing_button": "button3",
            "modifiers": { "optional": ["any"] }
          },
          "to": [{ "key_code": "left_control" }],
          "to_if_alone": [{ "pointing_button": "button3" }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1390 }] }
          ]
        }
      ]
    },
    {
      "description": "ist mouse: 進む(end) -> レイヤー中 録画/スクショ(⌘⇧5) / 通常クリック(button5)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "end",
            "modifiers": { "optional": ["any"] }
          },
          "to": [{ "key_code": "5", "modifiers": ["command", "shift"] }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1390 }] },
            { "type": "variable_if", "name": "button7_down", "value": 1 }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "end",
            "modifiers": { "optional": ["any"] }
          },
          "to_if_alone": [{ "pointing_button": "button5" }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1390 }] }
          ]
        }
      ]
    },
    {
      "description": "ist mouse: 戻る(home) -> レイヤー中 ⌘⌫ / 通常クリック(button4)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "home",
            "modifiers": { "optional": ["any"] }
          },
          "to": [
            { "key_code": "delete_or_backspace", "modifiers": ["command"] }
          ],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1390 }] },
            { "type": "variable_if", "name": "button7_down", "value": 1 }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "home",
            "modifiers": { "optional": ["any"] }
          },
          "to_if_alone": [{ "pointing_button": "button4" }],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1390 }] }
          ]
        }
      ]
    },
    {
      "description": "ist mouse: 親指下(button6) -> PopClip 起動",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "pointing_button": "button6",
            "modifiers": { "optional": ["any"] }
          },
          "to_if_alone": [
            {
              "shell_command": "osascript -e 'tell application \"PopClip\" to appear'"
            }
          ],
          "conditions": [
            { "type": "device_if", "identifiers": [{ "vendor_id": 1390 }] }
          ]
        }
      ]
    }
  ]
}
